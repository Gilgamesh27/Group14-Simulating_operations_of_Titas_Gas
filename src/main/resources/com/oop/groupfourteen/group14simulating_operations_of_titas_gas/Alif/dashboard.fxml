<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oop.groupfourteen.group14simulating_operations_of_titas_gas.Alif.DashboardController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #34495e; -fx-padding: 15;">
            <children>
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Common Dashboard" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="logoutBtn" mnemonicParsing="false" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Logout" />
            </children>
        </HBox>
        <HBox spacing="20.0">
            <children>
                <VBox fx:id="menuPanel" minWidth="200.0" spacing="10.0" style="-fx-background-color: #ecf0f1; -fx-padding: 20;">
                    <children>
                        <Button fx:id="button1" maxWidth="Infinity" mnemonicParsing="false" text="Gas Supply" />
                        <Button fx:id="button2" maxWidth="Infinity" mnemonicParsing="false" text="billing" />
                        <!-- Add more buttons for navigation -->
                    </children>
                </VBox>
                <StackPane fx:id="contentPane" style="-fx-padding: 20;" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </children>
</VBox>
